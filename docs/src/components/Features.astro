  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Fully Configurable",
    description: "Fine-tune intervals, patterns, enabled modules, and behavior via CLI flags or config file.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
    title: "Cross-Platform",
    description: "Native support for macOS, Linux, and Windows with platform-specific optimizations.",
  },
];
---

<section id="features" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center animate-on-scroll">
      <h2 class="mb-4 text-3xl font-bold sm:text-4xl">
        Everything you need to <span class="gradient-text">stay active</span>
      </h2>
      <p class="mx-auto max-w-2xl text-[var(--color-text-muted)]">
        Phantom combines multiple simulation modules to create convincing, human-like computer activity.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => (
        <div
          class="gradient-border animate-on-scroll rounded-xl p-6 backdrop-blur-sm"
          style={`animation-delay: ${i * 0.05}s`}
        >
          <div class="mb-3 inline-flex rounded-lg bg-gradient-to-br from-[var(--color-cyan)]/10 to-[var(--color-purple)]/10 p-2.5 text-[var(--color-cyan)]">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="mb-2 text-lg font-semibold">{feature.title}</h3>
          <p class="text-sm text-[var(--color-text-muted)]">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
