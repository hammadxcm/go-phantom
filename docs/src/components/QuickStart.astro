---
const steps = [
  {
    number: "1",
    title: "Install",
    description: "Install Phantom using your preferred package manager.",
    code: "pip install go-phantom",
  },
  {
    number: "2",
    title: "Run",
    description: "Start Phantom with the default configuration.",
    code: "phantom",
  },
  {
    number: "3",
    title: "Customize",
    description: "Fine-tune behavior with CLI flags or run the TUI dashboard.",
    code: "phantom --mouse --keyboard --interval 30\nphantom --tui",
  },
];
---

<section id="quickstart" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="mb-12 text-center animate-on-scroll">
      <h2 class="mb-4 text-3xl font-bold sm:text-4xl">
        Get started in <span class="gradient-text">seconds</span>
      </h2>
      <p class="text-[var(--color-text-muted)]">
        Three commands and you're up and running.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {steps.map((step, i) => (
        <div
          class="gradient-border animate-on-scroll rounded-xl p-6"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-cyan)] to-[var(--color-purple)] text-lg font-bold text-white">
            {step.number}
          </div>
          <h3 class="mb-2 text-lg font-semibold">{step.title}</h3>
          <p class="mb-4 text-sm text-[var(--color-text-muted)]">
            {step.description}
          </p>
          <div class="group relative">
            <pre class="overflow-x-auto rounded-lg bg-[var(--color-bg)] p-3 text-sm"><code class="font-mono text-[var(--color-cyan)]">{step.code}</code></pre>
            <button
              class="copy-btn absolute right-2 top-2 rounded-md p-1 text-[var(--color-text-muted)] opacity-0 transition-all hover:bg-[var(--color-border)] hover:text-[var(--color-text)] group-hover:opacity-100"
              data-copy={step.code}
              title="Copy to clipboard"
            >
              <svg class="copy-icon h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <svg class="check-icon hidden h-4 w-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
