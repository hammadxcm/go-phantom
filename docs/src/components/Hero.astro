---
const version = "0.0.3";
const downloadUrl = `https://github.com/hammadxcm/go-phantom/releases/download/v${version}`;
---

<section class="relative overflow-hidden px-4 pt-32 pb-20 sm:px-6 lg:px-8">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute top-1/4 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20 blur-[120px]"
      style="background: radial-gradient(circle, #06b6d4 0%, transparent 70%)"
    ></div>
    <div
      class="absolute top-1/3 right-1/4 h-[400px] w-[400px] rounded-full opacity-15 blur-[100px]"
      style="background: radial-gradient(circle, #a855f7 0%, transparent 70%)"
    ></div>
  </div>

  <div class="mx-auto max-w-4xl text-center">
    <div class="animate-on-scroll">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] px-4 py-1.5 text-sm text-[var(--color-text-muted)]">
        <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
        v{version} — Now available
      </div>

      <h1 class="mb-6 text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl">
        <span class="gradient-text">Phantom</span>
      </h1>

      <p class="mx-auto mb-4 max-w-2xl text-xl text-[var(--color-text-muted)] sm:text-2xl">
        Keep your computer awake with realistic human-like activity simulation.
      </p>

      <p class="mx-auto mb-10 max-w-xl text-[var(--color-text-muted)]">
        Cross-platform. Configurable. Undetectable. Phantom simulates mouse movements, keyboard input, scrolling, and app switching so your machine never sleeps.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="#downloads" class="btn-primary text-lg">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download v{version}
        </a>
        <a href="https://github.com/hammadxcm/go-phantom" target="_blank" rel="noopener" class="btn-secondary text-lg">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="mt-8 text-sm text-[var(--color-text-muted)]">
        Available on macOS · Linux · Windows &nbsp;|&nbsp; pip · brew · snap · choco · scoop
      </div>
    </div>
  </div>
</section>
